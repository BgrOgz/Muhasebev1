# =============================================
# FATURA OTOMASYONSİSTEMİ - .gitignore
# =============================================

# Ortam değişkenleri (ASLA commit etme!)
.env
*.env
.env.local
.env.production

# Gmail credentials
backend/config/credentials.json
backend/config/*.json

# Python
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Pytest
.pytest_cache/
.coverage
htmlcov/

# Node.js / React
frontend/node_modules/
frontend/build/
frontend/.env
frontend/.env.local

# Database
*.db
*.sqlite
*.sqlite3

# Yüklenen dosyalar
uploads/
archive/
*.xml
*.pdf

# Claude Code
.claude/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
*.log
logs/

# Docker
.docker/

# Alembic geçici
alembic/versions/__pycache__/

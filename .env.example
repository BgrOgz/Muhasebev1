# =============================================
# FATURA OTOMASYON SİSTEMİ — Environment Variables
# Kopyala: cp .env.example .env
# UYARI: .env dosyasını Git'e commit etme!
# =============================================

# ----- UYGULAMA -----
APP_ENV=development           # development | staging | production
APP_SECRET_KEY=BURAYA_GIZLI_ANAHTAR_YAZ   # openssl rand -hex 32
APP_URL=http://localhost:3000
DEBUG=True

# ----- VERİTABANI -----
DATABASE_URL=postgresql://fatura_user:sifre@localhost:5432/fatura_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ----- JWT AUTH -----
JWT_SECRET_KEY=BURAYA_JWT_ANAHTARI_YAZ    # openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ----- GMAIL (E-FATURA KAYNAĞI) -----
GMAIL_SERVICE_EMAIL=fatura@company.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx    # 16 karakter Google App Password
GMAIL_IMAP_SERVER=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_POLL_INTERVAL_MINUTES=5

# ----- CLAUDE AI -----
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXX
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ----- EMAIL BİLDİRİMLERİ (SMTP) -----
# SendGrid API ile veya doğrudan SMTP ile gönderim
SENDGRID_API_KEY=                         # Boş bırakılırsa SMTP kullanılır
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=fatura@company.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx         # Gmail App Password
FROM_EMAIL=noreply@company.com
FROM_NAME=Fatura Otomasyon Sistemi
NOTIFICATION_CC_EMAIL=                    # Opsiyonel: bildirim CC adresi

# ----- ONAY SİSTEMİ -----
FIRST_APPROVER_EMAIL=muhasebe@company.com
FINAL_APPROVER_EMAIL=patron@company.com
APPROVAL_REMINDER_HOURS=1
APPROVAL_MAX_REMINDERS=3

# ----- DOSYA YÜKLEME -----
MAX_FILE_SIZE_MB=25
ALLOWED_EXTENSIONS=xml,pdf,xls,xlsx
UPLOAD_DIR=./uploads

# ----- ARŞİV (10 YIL) -----
ARCHIVE_RETENTION_YEARS=10
ARCHIVE_DIR=./archive

# =============================================
# FATURA SİSTEMİ — Production Environment
# Bu dosyayı .env olarak kopyalayın ve doldurun
# cp .env.production.example .env
# =============================================

# ----- UYGULAMA -----
APP_ENV=production
APP_SECRET_KEY=BURAYA_EN_AZ_32_KARAKTER_GUCLU_BIR_SIFRE_GIRIN
APP_URL=https://DOMAIN_ADINIZ.COM
DEBUG=false
FRONTEND_URL=https://DOMAIN_ADINIZ.COM

# ----- VERİTABANI (docker-compose otomatik doldurur) -----
# DATABASE_URL docker-compose.yml içinde ayarlanıyor
DB_USER=fatura_user
DB_PASSWORD=BURAYA_GUCLU_DB_SIFRESI_GIRIN
DB_NAME=fatura_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ----- JWT AUTH -----
JWT_SECRET_KEY=BURAYA_EN_AZ_32_KARAKTER_GUCLU_JWT_ANAHTARI_GIRIN
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ----- ADMIN KULLANICI (ilk kurulum) -----
ADMIN_EMAIL=admin@firmanizinadresinizkoyun.com
ADMIN_PASSWORD=BURAYA_ADMIN_SIFRESI_GIRIN

# ----- GMAIL (E-FATURA KAYNAĞI) -----
GMAIL_SERVICE_EMAIL=faturalar@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
GMAIL_IMAP_SERVER=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_POLL_INTERVAL_MINUTES=5

# ----- CLAUDE AI -----
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-6

# ----- EMAIL BİLDİRİMLERİ (SMTP) -----
# Gmail SMTP kullanımı için:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=faturalar@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
FROM_EMAIL=faturalar@gmail.com
FROM_NAME=Fatura Otomasyon Sistemi
NOTIFICATION_CC_EMAIL=

# ----- ONAY SİSTEMİ -----
FIRST_APPROVER_EMAIL=muhasebe@firmanizinadresinizkoyun.com
FINAL_APPROVER_EMAIL=patron@firmanizinadresinizkoyun.com
APPROVAL_REMINDER_HOURS=24
APPROVAL_MAX_REMINDERS=3

# ----- DOSYA YÜKLEME -----
MAX_FILE_SIZE_MB=25
ALLOWED_EXTENSIONS=xml,pdf,xls,xlsx
UPLOAD_DIR=/app/uploads

# ----- ARŞİV -----
ARCHIVE_RETENTION_YEARS=10
ARCHIVE_DIR=/app/archive
